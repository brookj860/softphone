# ============================================================
#  UNIFIED SOFTPHONE — CONFIGURATION
#  Copy this file to .env and fill in your credentials
# ============================================================

# ── SERVER ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Your public URL (used to register webhooks, needed for Twilio callbacks)
# e.g. https://softphone.yourdomain.com  or  https://xxxx.ngrok.io
PUBLIC_URL=https://your-domain-here.com

# Secret key for signing sessions (any long random string)
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# ── TWILIO ───────────────────────────────────────────────────
# Found at: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio phone number (E.164 format, e.g. +441234567890)
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# TwiML App SID — create at:
# https://console.twilio.com → Voice → TwiML Apps → Create
# Set Voice Request URL to: {PUBLIC_URL}/api/voice/outbound
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API Key & Secret — create at:
# https://console.twilio.com → Account → API Keys → Create
# Needed to generate browser Access Tokens
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret_here

# ── META WHATSAPP BUSINESS ────────────────────────────────────
# All found at: https://developers.facebook.com → Your App → WhatsApp → API Setup

# Phone Number ID (NOT the phone number itself)
WA_PHONE_NUMBER_ID=1234567890123456

# Permanent System User Token — generate at:
# Business Settings → System Users → Add System User → Generate Token
# Required permissions: whatsapp_business_messaging, whatsapp_business_management
WA_PERMANENT_TOKEN=EAAxxxxxxxxxxxxxxxx

# WhatsApp Business Account ID
WA_BUSINESS_ACCOUNT_ID=1234567890123456

# Webhook Verify Token — any string YOU choose, then put the same value in
# Meta Developer Portal → WhatsApp → Configuration → Webhook → Verify Token
# Webhook URL should be: {PUBLIC_URL}/webhook/whatsapp
WA_WEBHOOK_VERIFY_TOKEN=my-webhook-verify-token-choose-anything

# ── OPTIONAL: RATE LIMITING ───────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
